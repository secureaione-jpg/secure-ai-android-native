    <string name="onboarding_title_1">Được cung cấp bởi Claude</string>
    <string name="onboarding_body_1">Secure AI được xây dựng trên Claude, mô hình tiên phong của Anthropic — chọn đúng mô hình Claude cho mỗi tác vụ.</string>
    <string name="onboarding_title_2">Riêng tư theo mặc định</string>
    <string name="onboarding_body_2">Danh tính của bạn không bao giờ đến được với AI. Mọi tin nhắn đều được định tuyến qua một proxy bảo mật — tên, email và IP của bạn luôn được ẩn.</string>
    <string name="onboarding_title_3">Ghi lại mọi thứ</string>
    <string name="onboarding_body_3">Ghi chú và ghi chú thoại được tự động phiên âm và tóm tắt — để những gì bạn ghi lại không bao giờ bị mất.</string>
    <string name="onboarding_title_4">Luôn ngăn nắp</string>
    <string name="onboarding_body_4">Dự án nhóm các cuộc trò chuyện, ghi chú và tệp của bạn theo những gì bạn đang làm — không gian làm việc AI cá nhân của bạn.</string>

