<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="new_chat"
        android:enabled="true"
        android:icon="@drawable/ic_new_chat"
        android:shortcutShortLabel="@string/shortcut_new_chat"
        android:shortcutLongLabel="@string/shortcut_new_chat_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="https://secureai.one/chat?new=1"
            android:targetPackage="one.secureai.app"
            android:targetClass="one.secureai.app.MainActivity" />
    </shortcut>

    <shortcut
        android:shortcutId="notes"
        android:enabled="true"
        android:icon="@drawable/ic_document"
        android:shortcutShortLabel="@string/shortcut_notes"
        android:shortcutLongLabel="@string/shortcut_notes_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="https://secureai.one/notes"
            android:targetPackage="one.secureai.app"
            android:targetClass="one.secureai.app.MainActivity" />
    </shortcut>


</shortcuts>
