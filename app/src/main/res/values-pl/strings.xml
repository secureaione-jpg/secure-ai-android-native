    <string name="onboarding_title_2">Prywatne domyślnie</string>
    <string name="onboarding_body_2">Twoja tożsamość nigdy nie dociera do AI. Każda wiadomość jest przesyłana przez serwer proxy chroniący prywatność — Twoje imię, e-mail i IP pozostają ukryte.</string>
    <string name="onboarding_title_3">Rejestruj wszystko</string>
    <string name="onboarding_body_3">Notatki i notatki głosowe, automatycznie transkrybowane i podsumowywane — dzięki czemu nic z tego, co zarejestrujesz, nie zostanie utracone.</string>
    <string name="onboarding_title_4">Zachowaj porządek</string>
    <string name="onboarding_body_4">Projekty grupują Twoje czaty, notatki i pliki według tego, nad czym pracujesz — Twoja osobista przestrzeń robocza AI.</string>

